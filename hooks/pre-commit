#!/bin/sh
# ============================================================
# Git Pre-Commit Hook — Security & Logic Quick Scan
# Runs automatically every time you do: git commit
# If any check FAILS, the commit is CANCELLED.
# To bypass in an emergency: git commit --no-verify
# ============================================================

RED='\033[0;31m'
YELLOW='\033[1;33m'
GREEN='\033[0;32m'
BOLD='\033[1m'
RESET='\033[0m'

PASS=0   # tracks whether commit should be blocked (0 = ok, 1 = block)

echo ""
echo "${BOLD}🔒 Security pre-commit scan starting...${RESET}"
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"

# ── CHECK 1: Hard-coded secret patterns ─────────────────────
echo ""
echo "${BOLD}[1/3] Scanning staged files for secrets...${RESET}"

STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM)

SECRET_HITS=""
for FILE in $STAGED_FILES; do
  case "$FILE" in
    *.md|*.lock|*.json) continue ;;
    *.env.example)      continue ;;
  esac

  MATCHES=$(git show ":$FILE" 2>/dev/null | grep -nE \
    "(API_KEY|SECRET_KEY|JWT_SECRET|PASSWORD|PRIVATE_KEY|ACCESS_TOKEN)\s*=\s*['\"][^'\"]{6,}" \
    2>/dev/null)

  if [ -n "$MATCHES" ]; then
    SECRET_HITS="${SECRET_HITS}\n  ${RED}► $FILE${RESET}\n$MATCHES"
    PASS=1
  fi
done

if [ -z "$SECRET_HITS" ]; then
  echo "  ${GREEN}✔ No hard-coded secrets detected${RESET}"
else
  echo "  ${RED}✖ Potential secrets found in staged files:${RESET}"
  printf "$SECRET_HITS\n"
fi

# ── CHECK 2: npm audit (HIGH/CRITICAL only) ──────────────────
echo ""
echo "${BOLD}[2/3] npm audit (HIGH & CRITICAL vulnerabilities)...${RESET}"

if [ -d "server" ] && [ -f "server/package.json" ]; then
  cd server
  AUDIT_OUT=$(npm audit --audit-level=high 2>&1)
  AUDIT_EXIT=$?

  if [ $AUDIT_EXIT -ne 0 ]; then
    echo "  ${RED}✖ HIGH or CRITICAL vulnerabilities found:${RESET}"
    echo "$AUDIT_OUT" | grep -E "(high|critical|moderate)" | head -20
    echo "  ${YELLOW}  Run: npm audit fix --dry-run   to preview fixes${RESET}"
    PASS=1
  else
    echo "  ${GREEN}✔ No HIGH/CRITICAL vulnerabilities${RESET}"
  fi

  cd ..
else
  echo "  ${YELLOW}⚠ server/ directory not found — skipping npm audit${RESET}"
fi

# ── CHECK 3: Detect 'eval' or 'innerHTML' in staged JS files ─
echo ""
echo "${BOLD}[3/3] Checking for dangerous patterns (eval, innerHTML)...${RESET}"

DANGER_HITS=""
for FILE in $STAGED_FILES; do
  case "$FILE" in
    *.js|*.jsx|*.ts|*.tsx) ;;
    *) continue ;;
  esac

  MATCHES=$(git show ":$FILE" 2>/dev/null | grep -nE \
    "\beval\s*\(|innerHTML\s*=|dangerouslySetInnerHTML|new\s+Function\s*\(" \
    2>/dev/null)

  if [ -n "$MATCHES" ]; then
    DANGER_HITS="${DANGER_HITS}\n  ${YELLOW}► $FILE${RESET}\n$MATCHES"
  fi
done

if [ -z "$DANGER_HITS" ]; then
  echo "  ${GREEN}✔ No dangerous API usage detected${RESET}"
else
  echo "  ${YELLOW}⚠ Potentially unsafe patterns found (review before merging):${RESET}"
  printf "$DANGER_HITS\n"
fi

# ── RESULT ───────────────────────────────────────────────────
echo ""
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"

if [ $PASS -ne 0 ]; then
  echo "${RED}${BOLD}✖ COMMIT BLOCKED — fix the issues above and try again.${RESET}"
  echo "${YELLOW}  To skip this check in an emergency: git commit --no-verify${RESET}"
  echo ""
  exit 1
fi

echo "${GREEN}${BOLD}✔ All checks passed — proceeding with commit.${RESET}"
echo ""
exit 0
